{
  "name": "admin",
  "version": "1.0.0",
  "description": "Admin Desktop App",
  "main": "main.js",
  "author": "Your Name",
  "scripts": {
    "dev": "cd ADMIN && npm run dev",
    "build": "cd ADMIN && npm run build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.achinta.admin",
    "productName": "Admin Panel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "preload.js",
      "package.json",
      "ADMIN/.next/**/*",
      "ADMIN/public/**/*",
      "ADMIN/package.json",
      "!ADMIN/node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Achinta Hazra co"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Achinta005",
        "repo": "appsy",
        "private": false
      }
    ]
  }
}